# Sphere — environment template.
#
# Copy this file to `.env` (same folder as docker-compose.yml) and fill in
# only the keys you actually have. Every adapter has an offline fallback,
# so the stack runs end-to-end with NO keys configured — values just come
# from synthetic / keyless public feeds instead of live providers.
#
#     cp .env.example .env
#
# Then edit `.env` and add keys you have. Do NOT commit `.env` (it's
# already gitignored). Both raw `npm run dev` / `uvicorn` workflows and
# `docker compose up` read this file's variables — docker compose picks
# them up automatically; for direct host runs export them in your shell
# or use a tool like `direnv`.
#
# Free-tier provider keys (relevant ones):
#   * Alpha Vantage (stocks/commodities/FX): https://www.alphavantage.co/support/#api-key  (25 req/day free)
#   * Anthropic (agentic narrative layer):    https://console.anthropic.com/settings/keys
# Everything else (weather, news, currency, conflict, disease, mood) uses
# keyless public feeds by default.
#
# =============================================================================
# REQUIRED (production / Railway)
# =============================================================================
# When deploying to Railway:
#   * `INTELLIGENCE_ENV=production` — switches the runtime into prod-strict mode.
#   * `INTELLIGENCE_DATABASE_URL` and `INTELLIGENCE_REDIS_URL` MUST be set in
#     production or the backend will refuse to boot. On Railway, attach the
#     Postgres + Redis plugins and reference their connection variables.
#   * `PORT` is injected by Railway automatically — do not set it manually.
#   * `NEXT_PUBLIC_API_BASE_URL` and `NEXT_PUBLIC_WS_BASE_URL` must point at
#     your deployed backend's public URL.

# ---- Backend (Railway / production) -----------------------------------------
# PORT is injected by Railway; defaults to 8000 locally.
# PORT=8000

# ---- Frontend (NEXT_PUBLIC_*) — REQUIRED ------------------------------------
# Local docker compose values. For Railway, set these to your backend's
# public URL (e.g. https://sphere-backend.up.railway.app and
# wss://sphere-backend.up.railway.app).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000

# ---- Legacy SPHERE_* (simulator + connection strings) — REQUIRED -------------
SPHERE_POSTGRES_DSN=postgresql://sphere:sphere@postgres:5432/sphere
SPHERE_REDIS_URL=redis://redis:6379/0
SPHERE_FRONTEND_ORIGIN=http://localhost:3000
SPHERE_ENABLE_SIMULATOR=true
SPHERE_SIMULATION_INTERVAL_MS=2500

# ---- Intelligence backbone (INTELLIGENCE_*) — REQUIRED in production ---------
# In `production` mode, both DATABASE_URL and REDIS_URL must be set or
# the backend raises at startup. In dev they fall back to in-memory
# repos so the stack still runs.
INTELLIGENCE_ENV=development
INTELLIGENCE_DATABASE_URL=
INTELLIGENCE_REDIS_URL=

# Ingest cadence + limits
INTELLIGENCE_INGEST_POLL_SECONDS=60
INTELLIGENCE_REQUEST_TIMEOUT_SECONDS=15
INTELLIGENCE_ENABLE_OFFLINE_FALLBACK=true
INTELLIGENCE_MAX_ITEMS_PER_SOURCE=200
INTELLIGENCE_CACHE_TTL_SECONDS=300

# =============================================================================
# OPTIONAL — every entry below is safe to leave blank.
# Adapters fall back to keyless public feeds or deterministic synthetic data
# when their key is missing, and the frontend surfaces a "Demo data" chip.
# =============================================================================

# Per-domain enable switches — set any to "false" to disable that adapter.
INTELLIGENCE_ENABLE_WEATHER=true
INTELLIGENCE_ENABLE_NEWS=true
INTELLIGENCE_ENABLE_FLIGHT=true
INTELLIGENCE_ENABLE_CONFLICT=true
INTELLIGENCE_ENABLE_DISEASE=true
INTELLIGENCE_ENABLE_MOOD=true
INTELLIGENCE_ENABLE_STOCKS=true
INTELLIGENCE_ENABLE_COMMODITIES=true
INTELLIGENCE_ENABLE_CURRENCY=true

# ---- Provider configuration (one block per adapter) — OPTIONAL ---------------
# Provider name + optional API key + optional base URL override. Leaving the
# API key blank keeps the adapter on its keyless / synthetic fallback.

# Weather (Open-Meteo + USGS, both keyless)
INTELLIGENCE_WEATHER_PROVIDER=open-meteo
INTELLIGENCE_WEATHER_API_KEY=
INTELLIGENCE_WEATHER_BASE_URL=

# Flight
INTELLIGENCE_FLIGHT_PROVIDER=aviationstack
INTELLIGENCE_FLIGHT_API_KEY=
INTELLIGENCE_FLIGHT_BASE_URL=

# News (GDELT, keyless)
INTELLIGENCE_NEWS_PROVIDER=gdelt
INTELLIGENCE_NEWS_API_KEY=
INTELLIGENCE_NEWS_BASE_URL=

# Conflict
INTELLIGENCE_CONFLICT_PROVIDER=acled
INTELLIGENCE_CONFLICT_API_KEY=
INTELLIGENCE_CONFLICT_BASE_URL=

# Disease
INTELLIGENCE_DISEASE_PROVIDER=healthmap
INTELLIGENCE_DISEASE_API_KEY=
INTELLIGENCE_DISEASE_BASE_URL=

# Mood
INTELLIGENCE_MOOD_PROVIDER=sentiment_proxy
INTELLIGENCE_MOOD_API_KEY=
INTELLIGENCE_MOOD_BASE_URL=

# Stocks (Alpha Vantage)
INTELLIGENCE_STOCKS_PROVIDER=alphavantage
INTELLIGENCE_STOCKS_API_KEY=
INTELLIGENCE_STOCKS_BASE_URL=

# Commodities (Alpha Vantage)
INTELLIGENCE_COMMODITIES_PROVIDER=alphavantage
INTELLIGENCE_COMMODITIES_API_KEY=
INTELLIGENCE_COMMODITIES_BASE_URL=

# Currency (Frankfurter, ECB-backed, keyless)
INTELLIGENCE_CURRENCY_PROVIDER=frankfurter
INTELLIGENCE_CURRENCY_API_KEY=
INTELLIGENCE_CURRENCY_BASE_URL=

# ---- Market data + chart candle provider — OPTIONAL --------------------------
# Powers /api/intelligence/market/{symbol}/candles, the holdings chart,
# and the 17A.1 posture engine.
#
# Provider options:
#   * polygon       — Polygon.io. Free tier serves up to 2y of daily
#                     aggregates, which is enough for SMA200.
#   * alphavantage  — Alpha Vantage. Free tier caps daily history at
#                     100 candles; technical engine falls back to SMA50.
#   * synthetic     — fully offline / deterministic series. Use for
#                     dev or CI runs without external network.
INTELLIGENCE_MARKET_DATA_PROVIDER=polygon
INTELLIGENCE_POLYGON_API_KEY=
INTELLIGENCE_POLYGON_BASE_URL=https://api.polygon.io
INTELLIGENCE_ALPHA_VANTAGE_API_KEY=
INTELLIGENCE_ALPHA_VANTAGE_BASE_URL=https://www.alphavantage.co

# ---- Bounded agentic narrative — OPTIONAL ------------------------------------
# When ANTHROPIC_API_KEY is unset, the /market/{symbol}/narrative endpoint
# returns a deterministic narrative built only from the typed posture envelope.
INTELLIGENCE_ANTHROPIC_API_KEY=
INTELLIGENCE_ANTHROPIC_MODEL=claude-haiku-4-5-20251001
INTELLIGENCE_ANTHROPIC_BASE_URL=https://api.anthropic.com
INTELLIGENCE_ANTHROPIC_REQUEST_TIMEOUT_SECONDS=12.0

# ---- LLM + embedding (search/agent surfaces) — OPTIONAL ----------------------
INTELLIGENCE_OPENAI_API_KEY=
INTELLIGENCE_OPENAI_MODEL=gpt-5.4
INTELLIGENCE_OLLAMA_BASE_URL=http://localhost:11434
INTELLIGENCE_OLLAMA_MODEL=
INTELLIGENCE_EMBEDDING_PROVIDER=openai
INTELLIGENCE_EMBEDDING_MODEL=text-embedding-3-large

# ---- Frontend extras — OPTIONAL ----------------------------------------------
# Cesium Ion token — only needed if you swap in Cesium tiles. Leave blank
# for the default Three.js globe.
NEXT_PUBLIC_CESIUM_ION_TOKEN=

# ---- Observability — OPTIONAL ------------------------------------------------
INTELLIGENCE_LOG_LEVEL=INFO
INTELLIGENCE_ENABLE_METRICS=true
INTELLIGENCE_ENABLE_TRACE_LOGGING=false
